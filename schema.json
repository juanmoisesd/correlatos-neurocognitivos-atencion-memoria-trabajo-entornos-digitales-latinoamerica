{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Neurocognitive Dataset Schema",
  "type": "object",
  "properties": {
    "subject_id": { "type": "string" },
    "age": { "type": "integer", "minimum": 0 },
    "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
    "digital_hours": { "type": "number", "minimum": 0 },
    "attention_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "wm_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "region": { "type": "string" }
  },
  "required": ["subject_id", "age", "gender", "digital_hours", "attention_score", "wm_score"]
}
